# Happily API — points at the production CMS at app.happily.events
HAPPILY_API_BASE_URL=https://app.happily.events
HAPPILY_API_SCHEMA_URL=https://app.happily.events/api/openapi.json

# Your event ID — find it in the URL when viewing your event in app.happily.events
# (e.g. app.happily.events/<EVENT_ID>/...)
HAPPILY_EVENT_ID=

# "staging" = fetch your draft event (use this while iterating)
# "prod"    = fetch only after you've published the event
HAPPILY_EVENT_ENV=staging
